{
  "expo": {
    "name": "KhaataWise",
    "slug": "khaata-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/khaatawise_dark.png",
    "scheme": "khaataapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.khaata.app"
    },
    "android": {
      "package": "com.khaata.app",
      "appName": "KhaataWise",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/khaatawise_dark.png",
        "backgroundColor": "#0a0a0c"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/khaatawise_dark.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow KhaataWise to access your photos to set profile pictures.",
          "cameraPermission": "Allow KhaataWise to access your camera to take profile pictures."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow KhaataWise to save cards to your gallery.",
          "savePhotosPermission": "Allow KhaataWise to save cards to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/khaatawise_dark.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0c",
          "dark": {
            "backgroundColor": "#0a0a0c"
          }
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d0dec0a4-1a8e-4bb3-9f1e-77259fdbbaf1"
      }
    }
  }
}
